// Flare Registry data model.
//
// A Provider is one organisation that runs a signal-provider operation. It owns one or more
// ProviderAddress rows (one per chain it operates on) and exactly one piece of branding
// (name, description, url, logo). Ownership is anchored to the on-chain address: a row only
// becomes verified after the wallet for that address signs a challenge.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Provider {
  id          String  @id @default(cuid())
  // Branding shown in the feed and directory.
  name        String
  description String
  url         String
  // Stored relative for self-hosted logos; the feed expands it to an absolute logoURI.
  logoPath    String?
  // For imported providers we keep the source's absolute logo URL verbatim until the owner
  // claims the entry and uploads their own. Null for natively-submitted providers.
  logoURI     String?
  // Provenance. "submitted" = created through the sign-in flow on this site. "imported" =
  // seeded from an external list and not yet owner-claimed.
  source      String  @default("submitted")

  // Self-declared fields: things the TowoLabs extended requirements list but that cannot be
  // verified on-chain, so they are provider-attested and shown labeled as "self-declared".
  // privateNode: submits prices from a private (not shared) node.
  privateNode Boolean? // null = not declared
  // algorithm: "in-house" | "open-source" | null (not declared).
  algorithm   String?

  // Governance (new-provider flag mechanism, see docs/governance-flag-mechanism.md).
  // flaggedOnce: this account has already been through the flag process once (once-only guard).
  flaggedOnce Boolean @default(false)
  // suspended: a DENIED flag outcome. Not Qualified, hidden from the default directory.
  suspended   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  addresses ProviderAddress[]
  flagCases ProviderFlagCase[]
}

// One on-chain address the provider operates, on one chain. This is the unit that gets
// verified and the unit that becomes a feed entry.
model ProviderAddress {
  id         String   @id @default(cuid())
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  providerId String

  // EVM chain id (14 Flare, 19 Songbird, 16 Coston, 114 Coston2).
  chainId Int
  // Lowercased 0x address. Unique per chain so two providers can't both claim it.
  address String

  // True only after a valid signature from this address is recorded, i.e. the owner has
  // claimed the entry. Imported entries start false even though they appear in the feed.
  verified   Boolean   @default(false)
  verifiedAt DateTime?

  // The feed's "listed" flag for this entry. For imported entries this carries the source
  // list's listed value verbatim. For owner-submitted entries it is true once verified.
  listed Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([chainId, address])
  @@index([providerId])
}

// One-time signing challenges. A nonce is issued for an address, consumed on successful
// verification, and expires shortly after issue so a leaked nonce is not reusable.
model AuthChallenge {
  id        String   @id @default(cuid())
  address   String // lowercased claimed address
  nonce     String   @unique
  expiresAt DateTime
  consumed  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([address])
}

// On-chain identity of a registered FTSO entity, ingested from the Flare-published
// fsp-rewards reward-epoch-info.json. One row per (identity voter address, network), updated
// to the latest epoch seen. Used to (a) match a Flare Registry listing to its on-chain entity by
// any of the entity's addresses, and (b) drive the "Registered" badge.
//
// Amounts/weights are wei-scale and stored as decimal strings; do bigint math in code.
model ProviderOnchain {
  id      String @id @default(cuid())
  // "flare" or "songbird".
  network String
  // Lowercased identity (voter) address — the entity's canonical key.
  voter   String

  delegationAddress       String?
  submitAddress           String?
  submitSignaturesAddress String?
  signingPolicyAddress    String?
  // Validator node ids the entity manages (JSON array of strings).
  nodeIds                 Json?

  // Current (latest-epoch) snapshot fields for quick display without scanning history.
  feeBips          Int?
  wNatWeight       String?
  wNatCappedWeight String?
  signingWeight    String?
  feedCount        Int?
  registered       Boolean @default(true)
  goodStanding     Boolean @default(true)
  // Member of Flare's on-chain FTSO Management Group (PollingManagementGroup contract): the
  // curated set of eligible, well-performing providers. Refreshed from a live RPC query.
  managementGroup  Boolean @default(false)

  lastEpochSeen Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([network, voter])
  @@index([delegationAddress])
  @@index([submitAddress])
  @@index([submitSignaturesAddress])
  @@index([signingPolicyAddress])
}

// Per-provider, per-reward-epoch metrics ingested from fsp-rewards. One row per
// (network, epochId, voter). Powers history, charts, and per-epoch liveness.
model ProviderMetricEpoch {
  id      String @id @default(cuid())
  network String
  epochId Int
  // Lowercased identity (voter) address.
  voter   String

  feeBips          Int?
  wNatWeight       String?
  wNatCappedWeight String?
  signingWeight    String?
  feedCount        Int?
  // The signing-policy threshold for this epoch (same for all providers in the epoch); a
  // provider "participates" when its signing weight meets/exceeds a meaningful share. Stored
  // per row for simplicity. Decimal string.
  epochThreshold   String?

  // Reward amounts attributed to this entity this epoch (wei-scale decimal strings).
  feeReward       String? // claimType 1 (provider commission)
  delegatorReward String? // claimType 2 (WNAT pool to the delegation address)
  stakerReward    String? // claimType 3 (mirror/staking)

  // Was the entity registered/active this epoch, and in good standing (no applied penalties).
  registered   Boolean @default(true)
  goodStanding Boolean @default(true)

  createdAt DateTime @default(now())

  @@unique([network, epochId, voter])
  @@index([network, voter])
  @@index([network, epochId])
}

// Tracks the highest reward epoch ingested per network, so the job only fetches new epochs.
model IngestState {
  network           String   @id
  lastEpochIngested Int      @default(0)
  updatedAt         DateTime @updatedAt
}

// Cached result of the address-on-website qualification check, keyed by provider url.
model WebsiteCheck {
  url       String   @id
  found     Boolean
  checkedAt DateTime @default(now())
}

// Persisted, LATCHING qualification state per on-chain entity. Qualification is sticky: once an
// entity becomes qualified it stays qualified, and the ONLY thing that revokes it is not
// submitting prices for ~9 consecutive reward epochs (30 days). After revocation it must
// re-qualify from scratch (full criteria, including the website-required onboarding window).
model QualificationState {
  id      String @id @default(cuid())
  network String
  voter   String // lowercased identity address

  qualified          Boolean   @default(false)
  // When the latch first turned on (also the restart point after a revocation).
  qualifiedAt        DateTime?
  // The most recent epoch in which this entity submitted/was present. Drives the no-submit gap.
  lastSubmittedEpoch Int?
  // The epoch at which qualification was last evaluated, so we only move forward.
  lastEvaluatedEpoch Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([network, voter])
}

// Governance: a flag case against a new provider, decided by the Management Group.
// See docs/governance-flag-mechanism.md for the full mechanism.
model ProviderFlagCase {
  id         String   @id @default(cuid())
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  providerId String
  network    String

  // OPEN_DISCUSSION | OPEN_VOTING | DENIED | CLEARED | FAILED_QUORUM
  state            String
  openedAt         DateTime  @default(now())
  discussionEndsAt DateTime
  votingEndsAt     DateTime
  decidedAt        DateTime?

  // True when this case is the one permitted appeal of a prior DENIED case.
  isReVote          Boolean @default(false)
  // Member count snapshot at open, for display. Live count is used at tally.
  memberCountAtOpen Int
  // Recorded at tally for the public record.
  outcomeTurnout    Int?
  outcomeDeny       Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  initiations   ProviderFlagInitiation[]
  votes         ProviderFlagVote[]
  voteRevisions ProviderFlagVoteRevision[]
  pointImages   ProviderFlagPointImage[]
  defense       ProviderFlagDefense?
}

// A Management Group member co-initiating a flag. Two distinct members open a case.
model ProviderFlagInitiation {
  id                String           @id @default(cuid())
  case              ProviderFlagCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  caseId            String
  // The member entity's identity (voter) address; one initiation per member entity per case.
  memberEntityVoter String
  signerAddress     String
  // Optional one-line subject for this point (falls back to "Point N" in the UI when null).
  title             String?
  // The CURRENT grounds text. The member can edit this while the case is still pre-vote; every
  // version (including the first) is preserved as a ProviderFlagGroundsRevision for the record.
  grounds           String
  createdAt         DateTime         @default(now())
  // Set when the grounds were last edited (null = never edited, still the original text).
  editedAt          DateTime?
  // Set when this co-initiator withdrew their flag (the case is then archived WITHDRAWN). The
  // initiation is kept for the public record rather than deleted.
  withdrawnAt       DateTime?

  revisions ProviderFlagGroundsRevision[]
  // Supplemental grounds the same member adds later (extra evidence/notes). Informational only:
  // they do NOT count as additional co-initiations; the primary `grounds` above is the one flag.
  entries   ProviderFlagGroundsEntry[]

  @@unique([caseId, memberEntityVoter])
}

// Append-only history of a flag's grounds. One row per version (the first is the original text);
// the member edits freely while the case is pre-vote, but no version is ever altered or removed,
// so the public record shows exactly what changed and when.
model ProviderFlagGroundsRevision {
  id           String                 @id @default(cuid())
  initiation   ProviderFlagInitiation @relation(fields: [initiationId], references: [id], onDelete: Cascade)
  initiationId String
  // The grounds + title as of this version (title null = no subject at that time).
  grounds      String
  title        String?
  // The address that signed this revision (the member's wallet at edit time).
  signerAddress String
  createdAt    DateTime               @default(now())

  @@index([initiationId])
}

// A supplemental grounds entry the flagging member adds after their first (e.g. new evidence). Each
// is independently editable with its own append-only revision history. Informational only: it does
// not affect co-initiation, quorum, or voting. Editable while the case is pre-vote.
model ProviderFlagGroundsEntry {
  id            String                 @id @default(cuid())
  initiation    ProviderFlagInitiation @relation(fields: [initiationId], references: [id], onDelete: Cascade)
  initiationId  String
  // Optional one-line subject (falls back to "Point N" in the UI when null).
  title         String?
  grounds       String
  signerAddress String
  createdAt     DateTime               @default(now())
  // Set when this entry was last edited (null = never edited).
  editedAt      DateTime?

  revisions ProviderFlagGroundsEntryRevision[]

  @@index([initiationId])
}

// Append-only version history for a supplemental grounds entry (mirrors ProviderFlagGroundsRevision
// for the primary grounds). The first row is the entry's original text.
model ProviderFlagGroundsEntryRevision {
  id            String                   @id @default(cuid())
  entry         ProviderFlagGroundsEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  entryId       String
  grounds       String
  title         String?
  signerAddress String
  createdAt     DateTime                 @default(now())

  @@index([entryId])
}

// A Management Group member's vote on a case. One vote per member entity per case.
model ProviderFlagVote {
  id                String           @id @default(cuid())
  case              ProviderFlagCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  caseId            String
  memberEntityVoter String
  signerAddress     String
  // "DENY" | "KEEP"
  vote              String
  comment           String?
  createdAt         DateTime         @default(now())
  // Bumped whenever the member changes their vote; equals createdAt for a vote never changed.
  updatedAt         DateTime         @default(now()) @updatedAt

  @@unique([caseId, memberEntityVoter])
}

// Append-only audit trail of every vote a member cast on a case, including changes. The current
// vote lives on ProviderFlagVote (one row per member); this keeps the FULL public history so a
// changed vote is transparent. One row per cast/change. Mirrors the grounds/defense revision pattern.
model ProviderFlagVoteRevision {
  id                String           @id @default(cuid())
  case              ProviderFlagCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  caseId            String
  memberEntityVoter String
  signerAddress     String
  // "DENY" | "KEEP"
  vote              String
  comment           String?
  createdAt         DateTime         @default(now())

  @@index([caseId, memberEntityVoter])
}

// The flagged provider's public defense statement, editable during the 14-day window.
// The flagged provider's public response. The primary `body` is the first response; the provider
// can edit it (history kept) and add supplemental responses, mirroring the members' grounds.
model ProviderFlagDefense {
  id        String           @id @default(cuid())
  case      ProviderFlagCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  caseId    String           @unique
  // Optional one-line subject (falls back to "Point N" in the UI when null).
  title     String?
  body      String
  updatedAt DateTime         @updatedAt
  createdAt DateTime         @default(now())
  // Set when the body was last edited (null = never edited since first posted).
  editedAt  DateTime?

  revisions ProviderFlagDefenseRevision[]
  entries   ProviderFlagDefenseEntry[]
}

// Append-only version history of the primary defense body (first row is the original text).
model ProviderFlagDefenseRevision {
  id        String              @id @default(cuid())
  defense   ProviderFlagDefense @relation(fields: [defenseId], references: [id], onDelete: Cascade)
  defenseId String
  body      String
  title     String?
  createdAt DateTime            @default(now())

  @@index([defenseId])
}

// A supplemental response the provider adds after their first, each independently editable with its
// own history. Mirrors ProviderFlagGroundsEntry for the members' side.
model ProviderFlagDefenseEntry {
  id        String              @id @default(cuid())
  defense   ProviderFlagDefense @relation(fields: [defenseId], references: [id], onDelete: Cascade)
  defenseId String
  // Optional one-line subject (falls back to "Point N" in the UI when null).
  title     String?
  body      String
  createdAt DateTime            @default(now())
  editedAt  DateTime?

  revisions ProviderFlagDefenseEntryRevision[]

  @@index([defenseId])
}

// Append-only version history for a supplemental defense entry.
model ProviderFlagDefenseEntryRevision {
  id        String                   @id @default(cuid())
  entry     ProviderFlagDefenseEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  entryId   String
  body      String
  title     String?
  createdAt DateTime                 @default(now())

  @@index([entryId])
}

// An evidence image attached to a single governance "point" (a member's grounds or the provider's
// response). Exactly one owner column is set, identifying which point it belongs to. Files live on
// local disk under uploads/governance/<caseId>/<id>.<ext>, served via /api/governance/image/<id>.
// Images are re-encoded on upload to strip EXIF/metadata. caseId is denormalized for fast lookup and
// path building, and cascades on case delete.
model ProviderFlagPointImage {
  id     String           @id @default(cuid())
  case   ProviderFlagCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  caseId String

  // Polymorphic owner: exactly one of these is non-null.
  initiationId   String? // primary grounds of a member's initiation
  groundsEntryId String? // a supplemental grounds entry
  defenseId      String? // primary provider response
  defenseEntryId String? // a supplemental provider response entry

  // Stored file facts. mime is the RE-ENCODED type we wrote (image/png|jpeg|webp).
  mime          String
  ext           String
  width         Int
  height        Int
  bytes         Int
  signerAddress String
  createdAt     DateTime @default(now())

  @@index([caseId])
  @@index([initiationId])
  @@index([groundsEntryId])
  @@index([defenseId])
  @@index([defenseEntryId])
}
