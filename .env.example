# Postgres connection string. Local docker (docker-compose.yml) maps the container to host
# port 5435 because 5432-5434 are taken on the dev box. On Hetzner, point this at the prod DB.
DATABASE_URL="postgresql://flareregistry:flareregistry@localhost:5435/flareregistry?schema=public"

# Secret used to sign session cookies (any long random string). REQUIRED in production; the app
# refuses to start without it (a missing secret would make session cookies forgeable).
SESSION_SECRET="change-me-to-a-long-random-value"

# Secret for the internal cron endpoints (evaluate-qualification, republish-feed, purge-stale).
# Falls back to SESSION_SECRET if unset; set a distinct value to decouple the two.
INTERNAL_API_SECRET=""

# The domain shown in the SIWE message the provider signs. Must match the site origin.
SIWE_DOMAIN="localhost:3000"
SIWE_URI="http://localhost:3000"

# Comma-separated lowercase addresses allowed into the admin moderation views.
ADMIN_ADDRESSES=""

# Where the public feed claims its logos live (raw asset base URL).
PUBLIC_BASE_URL="http://localhost:3000"

# Reown (WalletConnect) AppKit project ID, from dashboard.reown.com. Public-by-design (it ships to
# the browser), so this is not a secret like an API key. The site allowlist (flareregistry.com,
# localhost:3000) is configured in the Reown dashboard, not here. If unset, wallet connect falls back
# to a non-functional placeholder.
NEXT_PUBLIC_REOWN_PROJECT_ID=""

# Fine-grained GitHub PAT scoped to the public assets repo (Contents: read+write). Enables
# provider logo uploads. If unset, uploads are disabled and the endpoint reports it.
GITHUB_ASSETS_TOKEN=""
# Override the assets repo/branch if needed (defaults: BurstLabs/flareregistry, main).
# LOGO_REPO="BurstLabs/flareregistry"
# LOGO_BRANCH="main"

# --- Operator email (SMTP) --------------------------------------------------
# Used for OPERATOR-facing notices only: the contact form, logo upload/report notices, and consumer
# submissions. All go to CONTACT_TO. If unset, those features degrade gracefully (no send). This is
# the existing Zoho SMTP transport.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
# From identity for operator mail. Defaults to SMTP_USER if unset.
SMTP_FROM=""
# Where contact-form / notice emails are delivered (an operator inbox).
CONTACT_TO=""
# Optional: separate inbox for logo/consumer notices (defaults to CONTACT_TO).
# LOGO_NOTICE_TO=""

# --- Subscriber email (Resend) ----------------------------------------------
# Used for SUBSCRIBER-facing mail: provider-watch flag alerts to the general public. Sent from a
# flareregistry.com identity over Resend (SPF/DKIM aligned on our own domain) for deliverability, NOT
# from the operator's Zoho address. Resend speaks plain SMTP, so nodemailer is reused. If unset, the
# watch feature returns "email notifications are not available" instead of sending.
# Get the key at resend.com and verify the flareregistry.com domain (add its SPF/DKIM DNS records).
RESEND_API_KEY=""
# From identity for subscriber mail. Defaults to "Flare Registry <noreply@flareregistry.com>".
# PUBLIC_MAIL_FROM="Flare Registry <noreply@flareregistry.com>"
