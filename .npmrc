# @reown/appkit-adapter-wagmi pulls @wagmi/core, which lists optional account-abstraction peers
# (@privy-io/react-auth -> permissionless -> ox) that clash on ox versions. We do not use account
# abstraction (only personal_sign for SIWE), so that optional peer graph is irrelevant. legacy mode
# lets both `npm install` (dev) and `npm ci` (deploy) resolve consistently instead of hard-failing.
legacy-peer-deps=true
